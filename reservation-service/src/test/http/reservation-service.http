### 로그인
POST http://localhost:19091/api/v1/users/login
Content-Type: application/json

{
  "username": "tester",
  "password": "12345678a*"
}
> {%
    client.global.set("access_token", response.headers.valueOf("Authorization"))
%}



### 예약 생성 성공
POST http://localhost:19095/api/v1/reservations
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "flightId": "0e7d0581-2962-40ef-aa92-4105b46cca06",
  "seatCount": 2,
  "passengers": [
    {
      "name": "홍길동",
      "birth": "1995-03-15",
      "gender": "MALE",
      "passportNumber": "M12345678"
    },
   {
      "name": "홍길동2",
      "birth": "1993-08-21",
      "gender": "FEMALE",
      "passportNumber": "F98765432"
    }
  ]
}



### 예약 생성 실패 (Valid 테스트)
POST http://localhost:19095/api/v1/reservations
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "flightId": "49834e83-95e2-4a39-9d6a-36d7fe1d88ee",
  "seatCount": 2,
  "passengers": [
    {
      "name": "홍길동",
      "birth": "1995-03-15",
      "gender": "MALE",
      "passportNumber": "M1234567822222222222222"
    },
    {
      "name": "홍길동2",
      "birth": "1993-08-21022",
      "gender": "FEMALE",
      "passportNumber": "F98765432"
    }
  ]
}


### 예약 단일 조회
GET http://localhost:19095/api/v1/reservations/9b7f421f-47b0-47f5-aa5c-8f489697a57d
Content-Type: application/json
Authorization: Bearer {{access_token}}


## 예약 목록 조회
### 예약 목록 조회 - Default
GET http://localhost:19095/api/v1/reservations
Content-Type: application/json
Authorization: Bearer {{access_token}}



### 예약 목록 조회 - 1페이지, 5개씩 조회
GET http://localhost:19095/api/v1/reservations?page=1&size=5
Content-Type: application/json
Authorization: Bearer {{access_token}}


### 예약 확정(예약 수정)
PUT http://localhost:19095/api/v1/reservations/c8b4c5e1-4668-4055-bd2c-b0a6b2d18d1a/confirm
Content-Type: application/json
Authorization: Bearer {{access_token}}

{
  "tickets": [
    {
      "ticketId": "a87e3f99-c125-4155-8a51-2dc367af8e46",
      "passenger": {
        "name": "홍길동1",
        "birth": "1990-01-01",
        "gender": "MALE",
        "passportNumber": "P12345678"
      }
    },
    {
      "ticketId": "d5f61238-aef8-4d35-8d5f-bc4b130e4297",
      "passenger": {
        "name": "홍길동",
        "birth": "1995-06-10",
        "gender": "FEMALE",
        "passportNumber": "P87654321"
      }
    }
  ]
}


