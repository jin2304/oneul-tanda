### 예약 생성
POST http://localhost:19095/api/v1/reservations
Content-Type: application/json
X-User-ID: 9b7f421f-47b0-47f5-aa5c-8f489697a57d

{
  "userId": "9b7f421f-47b0-47f5-aa5c-8f489697a57d",
  "tickets": [
    {
      "flightId": "b84b09ef-1e4f-4cb2-9121-3ad86c013551",
      "seatClass": "ECONOMY",
      "price": 120000,
      "passenger": {
        "birth": "1995-03-15",
        "gender": "MALE",
        "passportNumber": "M12345678"
      }
    },
    {
      "flightId": "a123b09c-2d4f-4cb2-9999-1fdc3e001234",
      "seatClass": "BUSINESS",
      "price": 320000,
      "passenger": {
        "birth": "1993-08-21",
        "gender": "FEMALE",
        "passportNumber": "F98765432"
      }
    }
  ]
}



### 예약 단일 조회
GET http://localhost:19095/api/v1/reservations/9b7f421f-47b0-47f5-aa5c-8f489697a57d
Content-Type: application/json



## 예약 목록 조회
### 예약 목록 조회 - Default
GET http://localhost:19095/api/v1/reservations
Content-Type: application/json

### 예약 목록 조회 - 1페이지, 5개씩 조회
GET http://localhost:19095/api/v1/reservations?page=1&size=5
Content-Type: application/json



### 예약 확정(예약 수정)
PUT http://localhost:19095/api/v1/reservations/c8b4c5e1-4668-4055-bd2c-b0a6b2d18d1a/confirm
Content-Type: application/json

{
  "tickets": [
    {
      "ticketId": "a87e3f99-c125-4155-8a51-2dc367af8e46",
      "passenger": {
        "birth": "1990-01-01",
        "gender": "MALE",
        "passportNumber": "P12345678"
      }
    },
    {
      "ticketId": "d5f61238-aef8-4d35-8d5f-bc4b130e4297",
      "passenger": {
        "birth": "1995-06-10",
        "gender": "FEMALE",
        "passportNumber": "P87654321"
      }
    }
  ]
}